// Pandora Goat Farm ERP — Module 0: platform tables (Phase 3 §3)
// Later modules append models; migrations are additive only.

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

enum PermLevel {
  none
  view
  edit
  approve
}

model Farm {
  id            String   @id @db.Char(26)
  name          String
  address       String?
  district      String?
  state         String?
  pin           String?
  plotDetails   Json?    @map("plot_details")
  tagPrefix     String   @default("PGF") @map("tag_prefix")
  defaultLocale String   @default("bn") @map("default_locale")
  timezone      String   @default("Asia/Kolkata")
  createdAt     DateTime @default(now()) @map("created_at")
  updatedAt     DateTime @updatedAt @map("updated_at")

  @@map("farms")
}

model User {
  id               String    @id @db.Char(26)
  fullName         String    @map("full_name")
  phone            String    @unique
  email            String?
  passwordHash     String    @map("password_hash")
  locale           String    @default("bn")
  theme            String    @default("light")
  isActive         Boolean   @default(true) @map("is_active")
  failedLoginCount Int       @default(0) @map("failed_login_count")
  lockedUntil      DateTime? @map("locked_until")
  createdAt        DateTime  @default(now()) @map("created_at")
  createdBy        String?   @map("created_by") @db.Char(26)
  updatedAt        DateTime  @updatedAt @map("updated_at")
  updatedBy        String?   @map("updated_by") @db.Char(26)
  deletedAt        DateTime? @map("deleted_at")
  deletedBy        String?   @map("deleted_by") @db.Char(26)
  roles            UserRole[]
  sessions         Session[]

  @@map("users")
}

model Role {
  id          String           @id @db.Char(26)
  name        String           @unique
  isSystem    Boolean          @default(false) @map("is_system")
  permissions RolePermission[]
  users       UserRole[]

  @@map("roles")
}

model RolePermission {
  roleId String    @map("role_id") @db.Char(26)
  module String
  level  PermLevel
  role   Role      @relation(fields: [roleId], references: [id], onDelete: Cascade)

  @@id([roleId, module])
  @@map("role_permissions")
}

model UserRole {
  userId String @map("user_id") @db.Char(26)
  roleId String @map("role_id") @db.Char(26)
  user   User   @relation(fields: [userId], references: [id])
  role   Role   @relation(fields: [roleId], references: [id])

  @@id([userId, roleId])
  @@map("user_roles")
}

model Session {
  id        String   @id @db.Char(26)
  tokenHash String   @map("token_hash") @db.Char(64)
  userId    String   @map("user_id") @db.Char(26)
  createdAt DateTime @default(now()) @map("created_at")
  expiresAt DateTime @map("expires_at")
  ip        String?
  userAgent String?  @map("user_agent")
  user      User     @relation(fields: [userId], references: [id])

  @@index([userId])
  @@map("sessions")
}

model AuditLog {
  id         BigInt   @id @default(autoincrement())
  at         DateTime @default(now())
  actorId    String?  @map("actor_id") @db.Char(26)
  action     String
  entityType String   @map("entity_type")
  entityId   String?  @map("entity_id")
  before     Json?
  after      Json?
  requestId  String?  @map("request_id")

  @@index([entityType, entityId, at(sort: Desc)])
  @@index([actorId, at(sort: Desc)])
  @@map("audit_log")
}

model RecordVersion {
  id         String   @id @db.Char(26)
  entityType String   @map("entity_type")
  entityId   String   @map("entity_id") @db.Char(26)
  versionNo  Int      @map("version_no")
  snapshot   Json
  changedBy  String?  @map("changed_by") @db.Char(26)
  changedAt  DateTime @default(now()) @map("changed_at")

  @@unique([entityType, entityId, versionNo])
  @@map("record_versions")
}

model Setting {
  key       String   @id
  value     Json
  updatedAt DateTime @updatedAt @map("updated_at")
  updatedBy String?  @map("updated_by") @db.Char(26)

  @@map("settings")
}

model IdempotencyKey {
  key        String   @id @db.Uuid
  userId     String   @map("user_id") @db.Char(26)
  reqHash    String   @map("req_hash") @db.Char(64)
  status     Int
  response   Json?
  createdAt  DateTime @default(now()) @map("created_at")

  @@map("idempotency_keys")
}

// ── Module 1: Herd (Phase 3 §4) ─────────────────────────────────────

enum PenPurpose {
  general
  kidding
  buck
  kid
  isolation
  hospital
  quarantine
  fattening
}

enum AnimalSex {
  female
  male
  wether
}

enum AnimalSource {
  born_on_farm
  purchased
  gift
  exchange
  other
}

enum AnimalStatus {
  active
  sold
  died
  disposed
  culled
  lost
}

enum ExitType {
  sale
  death
  disposal
  cull_sale
  lost
}

model Breed {
  id                        String   @id @db.Char(26)
  name                      String   @unique
  nameBn                    String?  @map("name_bn")
  gestationDays             Int      @default(150) @map("gestation_days")
  adultWeightKg             Decimal? @map("adult_weight_kg") @db.Decimal(6, 3)
  pubertyAgeDays            Int?     @map("puberty_age_days")
  kiddingIntervalTargetDays Int      @default(240) @map("kidding_interval_target_days")
  animals                   Animal[]

  @@map("breeds")
}

model Shed {
  id     String  @id @db.Char(26)
  name   String  @unique
  nameBn String? @map("name_bn")
  pens   Pen[]

  @@map("sheds")
}

model Pen {
  id        String     @id @db.Char(26)
  shedId    String     @map("shed_id") @db.Char(26)
  name      String
  purpose   PenPurpose @default(general)
  capacity  Int?
  shed      Shed       @relation(fields: [shedId], references: [id])
  animals   Animal[]
  movesTo   PenMovement[] @relation("toPen")
  movesFrom PenMovement[] @relation("fromPen")

  @@unique([shedId, name])
  @@map("pens")
}

model Animal {
  id                 String       @id @db.Char(26)
  tagNumber          String       @map("tag_number") // partial-unique via SQL (deleted_at IS NULL)
  rfidTag            String?      @map("rfid_tag")
  name               String?
  breedId            String       @map("breed_id") @db.Char(26)
  crossPercent       Int?         @map("cross_percent")
  sex                AnimalSex
  birthDate          DateTime     @map("birth_date") @db.Date
  birthDateEstimated Boolean      @default(false) @map("birth_date_estimated")
  damId              String?      @map("dam_id") @db.Char(26)
  sireId             String?      @map("sire_id") @db.Char(26)
  source             AnimalSource
  purchasePrice      Decimal?     @map("purchase_price") @db.Decimal(12, 2)
  purchaseDate       DateTime?    @map("purchase_date") @db.Date
  supplierName       String?      @map("supplier_name")
  status             AnimalStatus @default(active)
  statusDate         DateTime?    @map("status_date") @db.Date
  currentPenId       String?      @map("current_pen_id") @db.Char(26)
  groupLabel         String?      @map("group_label")
  colorMarkings      String?      @map("color_markings")
  currentWeightKg    Decimal?     @map("current_weight_kg") @db.Decimal(6, 3)
  currentBcs         Decimal?     @map("current_bcs") @db.Decimal(2, 1)
  insurance          Json?
  medicalNotes       String?      @map("medical_notes")
  notes              String?
  photoAttachmentId  String?      @map("photo_attachment_id") @db.Char(26)
  createdAt          DateTime     @default(now()) @map("created_at")
  createdBy          String?      @map("created_by") @db.Char(26)
  updatedAt          DateTime     @updatedAt @map("updated_at")
  updatedBy          String?      @map("updated_by") @db.Char(26)
  deletedAt          DateTime?    @map("deleted_at")
  deletedBy          String?      @map("deleted_by") @db.Char(26)

  breed     Breed          @relation(fields: [breedId], references: [id])
  pen       Pen?           @relation(fields: [currentPenId], references: [id])
  dam       Animal?        @relation("dam", fields: [damId], references: [id])
  sire      Animal?        @relation("sire", fields: [sireId], references: [id])
  damKids   Animal[]       @relation("dam")
  sireKids  Animal[]       @relation("sire")
  weights   WeightRecord[]
  events    AnimalEvent[]
  movements PenMovement[]
  exit      AnimalExit?

  @@index([status])
  @@index([breedId])
  @@index([currentPenId])
  @@index([damId])
  @@index([sireId])
  @@map("animals")
}

model WeightRecord {
  id        String   @id @db.Char(26)
  animalId  String   @map("animal_id") @db.Char(26)
  weighedOn DateTime @map("weighed_on") @db.Date
  weightKg  Decimal  @map("weight_kg") @db.Decimal(6, 3)
  bcs       Decimal? @db.Decimal(2, 1)
  method    String   @default("scale")
  notes     String?
  createdAt DateTime @default(now()) @map("created_at")
  createdBy String?  @map("created_by") @db.Char(26)
  animal    Animal   @relation(fields: [animalId], references: [id])

  @@unique([animalId, weighedOn])
  @@index([animalId, weighedOn(sort: Desc)])
  @@map("weight_records")
}

model AnimalEvent {
  id            String   @id @db.Char(26)
  animalId      String   @map("animal_id") @db.Char(26)
  eventType     String   @map("event_type")
  occurredAt    DateTime @map("occurred_at")
  refType       String?  @map("ref_type")
  refId         String?  @map("ref_id")
  summaryCode   String   @map("summary_code")
  summaryParams Json?    @map("summary_params")
  createdAt     DateTime @default(now()) @map("created_at")
  createdBy     String?  @map("created_by") @db.Char(26)
  animal        Animal   @relation(fields: [animalId], references: [id])

  @@index([animalId, occurredAt(sort: Desc)])
  @@index([eventType, occurredAt])
  @@map("animal_events")
}

model PenMovement {
  id        String   @id @db.Char(26)
  animalId  String   @map("animal_id") @db.Char(26)
  fromPenId String?  @map("from_pen_id") @db.Char(26)
  toPenId   String   @map("to_pen_id") @db.Char(26)
  movedAt   DateTime @map("moved_at")
  reason    String   @default("routine")
  notes     String?
  createdBy String?  @map("created_by") @db.Char(26)
  animal    Animal   @relation(fields: [animalId], references: [id])
  fromPen   Pen?     @relation("fromPen", fields: [fromPenId], references: [id])
  toPen     Pen      @relation("toPen", fields: [toPenId], references: [id])

  @@map("pen_movements")
}

model AnimalExit {
  id             String   @id @db.Char(26)
  animalId       String   @unique @map("animal_id") @db.Char(26)
  exitType       ExitType @map("exit_type")
  exitDate       DateTime @map("exit_date") @db.Date
  buyerName      String?  @map("buyer_name")
  liveWeightKg   Decimal? @map("live_weight_kg") @db.Decimal(6, 3)
  price          Decimal? @db.Decimal(12, 2)
  causeCategory  String?  @map("cause_category")
  causeDetail    String?  @map("cause_detail")
  postMortemDone Boolean? @map("post_mortem_done")
  disposalMethod String?  @map("disposal_method")
  notes          String?
  createdAt      DateTime @default(now()) @map("created_at")
  createdBy      String?  @map("created_by") @db.Char(26)
  animal         Animal   @relation(fields: [animalId], references: [id])

  @@map("animal_exits")
}

model Attachment {
  id          String   @id @db.Char(26)
  entityType  String   @map("entity_type")
  entityId    String   @map("entity_id") @db.Char(26)
  kind        String   @default("photo")
  filePath    String   @map("file_path")
  contentHash String   @map("content_hash") @db.Char(64)
  mime        String
  sizeBytes   Int      @map("size_bytes")
  caption     String?
  createdAt   DateTime @default(now()) @map("created_at")
  createdBy   String?  @map("created_by") @db.Char(26)

  @@index([entityType, entityId])
  @@map("attachments")
}

// ── Module 2: Breeding (Phase 3 §5) ─────────────────────────────────

enum ServiceType {
  natural
  ai
}

enum DiagnosisMethod {
  ultrasound
  palpation
  non_return
  ballottement
  other
}

enum DiagnosisResult {
  pregnant
  open
  inconclusive
}

enum PregnancyStatus {
  ongoing
  kidded
  aborted
  false_pregnancy
}

model HeatRecord {
  id         String   @id @db.Char(26)
  doeId      String   @map("doe_id") @db.Char(26)
  detectedOn DateTime @map("detected_on") @db.Date
  signs      String?
  notes      String?
  createdAt  DateTime @default(now()) @map("created_at")
  createdBy  String?  @map("created_by") @db.Char(26)

  @@index([doeId, detectedOn(sort: Desc)])
  @@map("heat_records")
}

model Service {
  id                 String      @id @db.Char(26)
  doeId              String      @map("doe_id") @db.Char(26)
  serviceType        ServiceType @map("service_type")
  buckId             String?     @map("buck_id") @db.Char(26)
  semenBatch         String?     @map("semen_batch")
  semenSource        String?     @map("semen_source")
  technician         String?
  serviceDate        DateTime    @map("service_date") @db.Date
  heatRecordId       String?     @map("heat_record_id") @db.Char(26)
  overrideReason     String?     @map("override_reason")
  inbreedingFlag     Boolean     @default(false) @map("inbreeding_flag")
  notes              String?
  createdAt          DateTime    @default(now()) @map("created_at")
  createdBy          String?     @map("created_by") @db.Char(26)
  diagnoses          PregnancyDiagnosis[]
  pregnancy          Pregnancy?

  @@index([doeId, serviceDate(sort: Desc)])
  @@index([buckId, serviceDate(sort: Desc)])
  @@map("services")
}

model PregnancyDiagnosis {
  id          String          @id @db.Char(26)
  serviceId   String          @map("service_id") @db.Char(26)
  diagnosedOn DateTime        @map("diagnosed_on") @db.Date
  method      DiagnosisMethod
  result      DiagnosisResult
  notes       String?
  createdAt   DateTime        @default(now()) @map("created_at")
  createdBy   String?         @map("created_by") @db.Char(26)
  service     Service         @relation(fields: [serviceId], references: [id])

  @@map("pregnancy_diagnoses")
}

model Pregnancy {
  id                  String          @id @db.Char(26)
  doeId               String          @map("doe_id") @db.Char(26)
  serviceId           String          @unique @map("service_id") @db.Char(26)
  confirmedOn         DateTime        @map("confirmed_on") @db.Date
  expectedKiddingDate DateTime        @map("expected_kidding_date") @db.Date
  status              PregnancyStatus @default(ongoing)
  abortionDate        DateTime?       @map("abortion_date") @db.Date
  abortionReason      String?         @map("abortion_reason")
  notes               String?
  createdAt           DateTime        @default(now()) @map("created_at")
  createdBy           String?         @map("created_by") @db.Char(26)
  service             Service         @relation(fields: [serviceId], references: [id])
  kidding             Kidding?

  @@index([status, expectedKiddingDate])
  @@index([doeId])
  @@map("pregnancies")
}

model Kidding {
  id                String     @id @db.Char(26)
  pregnancyId       String     @unique @map("pregnancy_id") @db.Char(26)
  kiddingDate       DateTime   @map("kidding_date") @db.Date
  assisted          Boolean    @default(false)
  complication      String     @default("none")
  complicationNotes String?    @map("complication_notes")
  totalBorn         Int        @map("total_born")
  bornAlive         Int        @map("born_alive")
  attendedBy        String?    @map("attended_by")
  notes             String?
  createdAt         DateTime   @default(now()) @map("created_at")
  createdBy         String?    @map("created_by") @db.Char(26)
  pregnancy         Pregnancy  @relation(fields: [pregnancyId], references: [id])
  kidRecords        KidRecord[]

  @@map("kiddings")
}

model KidRecord {
  animalId         String    @id @map("animal_id") @db.Char(26)
  kiddingId        String    @map("kidding_id") @db.Char(26)
  birthOrder       Int       @map("birth_order")
  birthWeightKg    Decimal?  @map("birth_weight_kg") @db.Decimal(5, 3)
  colostrumWithin1h Boolean? @map("colostrum_within_1h")
  weanedOn         DateTime? @map("weaned_on") @db.Date
  weaningWeightKg  Decimal?  @map("weaning_weight_kg") @db.Decimal(6, 3)
  kidding          Kidding   @relation(fields: [kiddingId], references: [id])

  @@index([kiddingId])
  @@map("kid_records")
}
