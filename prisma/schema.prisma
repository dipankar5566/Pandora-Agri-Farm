// Pandora Goat Farm ERP — Module 0: platform tables (Phase 3 §3)
// Later modules append models; migrations are additive only.

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

enum PermLevel {
  none
  view
  edit
  approve
}

model Farm {
  id            String   @id @db.Char(26)
  name          String
  address       String?
  district      String?
  state         String?
  pin           String?
  plotDetails   Json?    @map("plot_details")
  tagPrefix     String   @default("PGF") @map("tag_prefix")
  defaultLocale String   @default("bn") @map("default_locale")
  timezone      String   @default("Asia/Kolkata")
  createdAt     DateTime @default(now()) @map("created_at")
  updatedAt     DateTime @updatedAt @map("updated_at")

  @@map("farms")
}

model User {
  id               String    @id @db.Char(26)
  fullName         String    @map("full_name")
  phone            String    @unique
  email            String?
  passwordHash     String    @map("password_hash")
  locale           String    @default("bn")
  theme            String    @default("light")
  isActive         Boolean   @default(true) @map("is_active")
  failedLoginCount Int       @default(0) @map("failed_login_count")
  lockedUntil      DateTime? @map("locked_until")
  createdAt        DateTime  @default(now()) @map("created_at")
  createdBy        String?   @map("created_by") @db.Char(26)
  updatedAt        DateTime  @updatedAt @map("updated_at")
  updatedBy        String?   @map("updated_by") @db.Char(26)
  deletedAt        DateTime? @map("deleted_at")
  deletedBy        String?   @map("deleted_by") @db.Char(26)
  roles            UserRole[]
  sessions         Session[]

  @@map("users")
}

model Role {
  id          String           @id @db.Char(26)
  name        String           @unique
  isSystem    Boolean          @default(false) @map("is_system")
  permissions RolePermission[]
  users       UserRole[]

  @@map("roles")
}

model RolePermission {
  roleId String    @map("role_id") @db.Char(26)
  module String
  level  PermLevel
  role   Role      @relation(fields: [roleId], references: [id], onDelete: Cascade)

  @@id([roleId, module])
  @@map("role_permissions")
}

model UserRole {
  userId String @map("user_id") @db.Char(26)
  roleId String @map("role_id") @db.Char(26)
  user   User   @relation(fields: [userId], references: [id])
  role   Role   @relation(fields: [roleId], references: [id])

  @@id([userId, roleId])
  @@map("user_roles")
}

model Session {
  id        String   @id @db.Char(26)
  tokenHash String   @map("token_hash") @db.Char(64)
  userId    String   @map("user_id") @db.Char(26)
  createdAt DateTime @default(now()) @map("created_at")
  expiresAt DateTime @map("expires_at")
  ip        String?
  userAgent String?  @map("user_agent")
  user      User     @relation(fields: [userId], references: [id])

  @@index([userId])
  @@map("sessions")
}

model AuditLog {
  id         BigInt   @id @default(autoincrement())
  at         DateTime @default(now())
  actorId    String?  @map("actor_id") @db.Char(26)
  action     String
  entityType String   @map("entity_type")
  entityId   String?  @map("entity_id")
  before     Json?
  after      Json?
  requestId  String?  @map("request_id")

  @@index([entityType, entityId, at(sort: Desc)])
  @@index([actorId, at(sort: Desc)])
  @@map("audit_log")
}

model RecordVersion {
  id         String   @id @db.Char(26)
  entityType String   @map("entity_type")
  entityId   String   @map("entity_id") @db.Char(26)
  versionNo  Int      @map("version_no")
  snapshot   Json
  changedBy  String?  @map("changed_by") @db.Char(26)
  changedAt  DateTime @default(now()) @map("changed_at")

  @@unique([entityType, entityId, versionNo])
  @@map("record_versions")
}

model Setting {
  key       String   @id
  value     Json
  updatedAt DateTime @updatedAt @map("updated_at")
  updatedBy String?  @map("updated_by") @db.Char(26)

  @@map("settings")
}

model IdempotencyKey {
  key        String   @id @db.Uuid
  userId     String   @map("user_id") @db.Char(26)
  reqHash    String   @map("req_hash") @db.Char(64)
  status     Int
  response   Json?
  createdAt  DateTime @default(now()) @map("created_at")

  @@map("idempotency_keys")
}
