# Copy to .env — never commit .env
DATABASE_URL="postgresql://localhost:5432/pandora_erp"
PORT=3300
NODE_ENV=development
# Session cookie is HTTP-only; secret signs nothing (tokens are random+hashed) but kept for future use
SESSION_TTL_DAYS=30
SEED_OWNER_PHONE=9999999999
SEED_OWNER_PASSWORD=change-me
