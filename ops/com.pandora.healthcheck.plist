<?xml version="1.0" encoding="UTF-8"?>
<!DOCTYPE plist PUBLIC "-//Apple//DTD PLIST 1.0//EN" "http://www.apple.com/DTDs/PropertyList-1.0.dtd">
<plist version="1.0">
<dict>
  <key>Label</key><string>com.pandora.healthcheck</string>
  <key>ProgramArguments</key>
  <array><string>/bin/zsh</string><string>__ROOT__/ops/check-jobs.sh</string></array>
  <key>StartCalendarInterval</key>
  <dict><key>Hour</key><integer>6</integer><key>Minute</key><integer>15</integer></dict>
  <key>StandardErrorPath</key><string>/tmp/pandora-healthcheck.err</string>
</dict>
</plist>
